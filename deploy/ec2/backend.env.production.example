# Backend runtime secrets — copy to backend/.env on the server. Never commit filled copy.

# RDS (platform-provided)
DB_HOST=your-rds-host.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=caliper_cv_screening_user
DB_NAME=caliper_cv_screening
DB_PASSWORD=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=caliper-cv-screening

GOOGLE_CLIENT_ID=
ENCRYPTION_MASTER_KEY=
DEFAULT_WORKSPACE_ID=
ALLOWED_EMAIL_DOMAINS=nextventures.io,wearenext.io,fn.com

PORT=3001
NODE_ENV=production

# Recruitee — platform-managed (not entered by users in Settings)
RECRUITEE_COMPANY_ID=nextventures
RECRUITEE_COMPANY_NUMERIC_ID=117606
# RECRUITEE_BASE_URL=https://api.recruitee.com/c/nextventures
RECRUITEE_API_KEY=
RECRUITEE_TLS_INSECURE=true

# SMTP (Amazon SES) — workspace invites + screening run alerts
SMTP_HOST=email-smtp.eu-west-2.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@nextventures.io
APP_URL=https://caliper.nextventures.io

# Optional integrations (Exa, Serper, Nubela)
