# Root build-time vars for docker-compose.prod.yml (copy to repo root .env on server)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Public API URL users hit in the browser (usually https://your-domain/api or dedicated API host)
VITE_API_URL=https://your-domain.example.com/api
# Must match the public frontend origin exactly (https, no trailing slash)
CORS_ORIGIN=https://your-domain.example.com
