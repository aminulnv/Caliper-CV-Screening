# PostgreSQL — AWS RDS (TLS is required for *.rds.amazonaws.com; enabled automatically)
# Option A: single connection string
# DATABASE_URL=postgresql://user:password@your-rds-host.ap-south-1.rds.amazonaws.com:5432/caliper
# Option B: platform-provided components (password URL-encoded if it contains special chars)
DB_HOST=your-rds-host.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=caliper_cv_screening_user
DB_NAME=caliper_cv_screening
DB_PASSWORD=your-password
# DATABASE_SSL=false  # only for local Postgres without TLS
# DATABASE_TLS_INSECURE=true  # RDS TLS with rejectUnauthorized:false (if CA chain fails on host)

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=caliper-cv-files

# Google OAuth — same client ID as VITE_GOOGLE_CLIENT_ID (used to verify ID token audience)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Comma-separated email domains allowed to sign in (e.g. nextventures.io,wearenext.io)
ALLOWED_EMAIL_DOMAINS=nextventures.io,wearenext.io,fn.com

# Default workspace UUID — new SSO users are auto-provisioned here as recruiter
DEFAULT_WORKSPACE_ID=your-workspace-uuid

# Encryption master key for workspace API keys (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=your-64-char-hex-key

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Platform Recruitee (production) — set on server; users do not enter keys in Settings UI
# RECRUITEE_COMPANY_ID=nextventures
# RECRUITEE_COMPANY_NUMERIC_ID=117606
# RECRUITEE_BASE_URL=https://api.recruitee.com/c/nextventures
# RECRUITEE_API_KEY=your-recruitee-api-token

# Dev only: allow Recruitee API through corporate VPN SSL inspection (self-signed cert in chain)
# RECRUITEE_TLS_INSECURE=true

# Data retention job (defaults: enabled, runs every 24h, first run 1 min after startup)
# RETENTION_ENABLED=false
# RETENTION_INTERVAL_MS=86400000

# Recruitee job sync (defaults: enabled, every 15 min, first run 30s after startup)
# RECRUITEE_SYNC_ENABLED=false
# RECRUITEE_SYNC_INTERVAL_MS=900000

# Related profiles — Exa (default) or Serper.dev for LinkedIn URL discovery
# Exa: https://dashboard.exa.ai — people search with semantic queries
# EXA_API_KEY=
# LINKEDIN_SEARCH_PROVIDER=exa  # exa | auto | serper (default: exa when EXA_API_KEY is set)
# LINKEDIN_SEARCH_SERPER_FALLBACK=true  # opt-in: fall back to Serper if Exa fails
# Serper: https://serper.dev/api-keys (optional fallback)
# SERPER_API_KEY=
# SERPER_API_KEYS=key_one,key_two
# NUBELA_API_KEY=  # fallback when Exa text is thin or fields can't be parsed (see NUBELA_FALLBACK)
# PROXYCURL_API_KEY=  # legacy alias for NUBELA_API_KEY
# NUBELA_FALLBACK=true  # when false, never call Nubela even if key is set
# RELATED_PROFILES_AUTO_SCORE=true  # AI 1–5 star JD alignment from Exa text (default: on; set false to disable)
# LINKEDIN_DISCOVERY_MODE=mock  # dev only — fake profiles; omit in production
