# Supabase: Project URL and anon (public) key from Dashboard → Project Settings → API
#
# Important: do NOT leave the template values below in .env — requests to
# https://your-project-ref.supabase.co can hang, which keeps the app on "Loading…"
# forever. Replace both with your real project URL and anon key.
#
# --- Local UI without Supabase (dev only) ---
# Set to 1 to skip Supabase auth and use a fixed local user (see Login page).
# You can omit VITE_SUPABASE_* when this is set (defaults are filled in for the client).
# VITE_DEV_DUMMY_AUTH=1
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
