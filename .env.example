# Google OAuth — Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API (defaults to http://localhost:3001 in dev if omitted)
VITE_API_URL=http://localhost:3001

# Talent Search UI + API (set true after pgvector + migrate-cv-embeddings on backend)
# VITE_SEMANTIC_CV_SEARCH_ENABLED=true
