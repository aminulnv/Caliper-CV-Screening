# Amazon Cognito — AWS Console → User Pools → your pool
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your-app-client-id
# Hosted UI domain (without https://) — Branding → Domain
VITE_COGNITO_DOMAIN=your-prefix.auth.ap-south-1.amazoncognito.com

# Backend API (defaults to http://localhost:3001 in dev if omitted)
VITE_API_URL=http://localhost:3001
