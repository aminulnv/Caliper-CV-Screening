# Fixes npm install when you see: SELF_SIGNED_CERT_IN_CHAIN (common on VPN / corporate SSL inspection).
# Trade-off: TLS verification to the npm registry is disabled for this project only.
# Safer alternative: ask IT for the corporate root CA and use: npm config set cafile /path/to/cert.pem
# Then delete this file or set strict-ssl=true.
strict-ssl=false
